{
  "display_information": {
    "name": "Slink Bot",
    "description": "A lightweight Elixir Slack bot",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "slink",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/slink",
        "description": "Say hi",
        "usage_hint": "[text]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "commands",
        "channels:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
